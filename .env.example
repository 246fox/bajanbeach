# Public site
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — never expose to the browser (admin saves + SSR reads for sargassum)
SUPABASE_SERVICE_ROLE_KEY=

# Admin UI — plain password for /admin/login → JWT cookie
ADMIN_PASSWORD=

# Google Maps / Places (beach hero photos + embeds)
# Prefer GOOGLE_MAPS_KEY for Places (Text Search + Place Details) — same key is fine if unrestricted.
# If only NEXT_PUBLIC_GOOGLE_MAPS_KEY is set, photo lookups use it server-side; keep Places API enabled and watch daily quotas (63 beaches × 2 calls each on cold cache).
GOOGLE_MAPS_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
